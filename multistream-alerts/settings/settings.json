            "defaultValue": "",
            "group": "Erscheinungsbild"
        },
        {
            "id": "fontSize",
            "label": "Schriftgröße",
            "description": "",
            "type": "number",
            "min": 1,
            "max": 120,
            "defaultValue": 20,
            "group": "Erscheinungsbild"
        },
        {
            "id": "fontColor",
            "label": "Schriftfarbe",
            "description": "",
            "type": "color",
            "defaultValue": "#FFFFFF",
