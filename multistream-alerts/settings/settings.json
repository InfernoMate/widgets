            "type": "select",
            "options": [
                {
                    "value": "fade-in",
                    "label": "Einblenden"
                },
                {
                    "value": "slide-in-from-top",
                    "label": "Von oben einblenden"
                },
                {
                    "value": "slide-in-from-bottom",
                    "label": "Von unten einblenden"
                },
                {
                    "value": "slide-in-from-left",
                    "label": "Von links einblenden"
                },
                {
                    "value": "slide-in-from-right",
                    "label": "Von rechts einblenden"
                }
            ],
            "defaultValue": "slide-in-from-bottom",
            "group": "Allgemein"
        },
        {
            "id": "hideAnimation",
            "label": "Ausblend-Animation",
