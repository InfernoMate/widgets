            "type": "number",
            "defaultValue": "0.85",
            "min": 0,
            "max": 1,
            "step": ".01",
            "showIf": "useCustomBackground",
            "group": "Erscheinungsbild"
        },
        {
            "id": "textAlignment",
            "label": "Textausrichtung",
            "description": "",
            "type": "select",
            "options": [
                {
                    "value": "left",
                    "label": "Links"
                },
                {
                    "value": "center",
                    "label": "Zentriert"
                },
                {
                    "value": "right",
                    "label": "Rechts"
                }
            ],
            "defaultValue": "left",
            "group": "Erscheinungsbild"
        },
        {
            "id": "alignment",
            "label": "Ausrichtung der Benachrichtigung",
            "description": "",
            "type": "select",
            "options": [
                {
                    "value": "align-to-top",
                    "label": "Oben ausrichten"
                },
                {
                    "value": "align-to-center",
                    "label": "Mittig ausrichten"
                },
                {
                    "value": "align-to-bottom",
                    "label": "Unten ausrichten"
                }
            ],
            "defaultValue": "align-to-bottom",
            "group": "Erscheinungsbild"
        },
        {
            "id": "hideAfter",
